# Agent Smith runtime
SMITH_ENV=development
SMITH_PERMISSION_LEVEL=0
SMITH_SERVICE_NAME=agent-smith

# Database
DATABASE_URL=postgres://smith:smith_password@postgres:5432/smith

# Schema adapter for supervised Postgres systems
SMITH_SCHEMA_PROFILE=generic
SMITH_JOBS_TABLE=jobs
SMITH_ERRORS_TABLE=errors
SMITH_APPROVALS_TABLE=approvals
SMITH_JOBS_ID_COLUMN=id
SMITH_JOBS_STATUS_COLUMN=status
SMITH_JOBS_CREATED_AT_COLUMN=created_at
SMITH_JOBS_UPDATED_AT_COLUMN=updated_at
SMITH_JOBS_TITLE_COLUMN=
SMITH_JOBS_CLIENT_ID_COLUMN=
SMITH_JOBS_WORKFLOW_RUN_ID_COLUMN=
SMITH_ERRORS_ID_COLUMN=id
SMITH_ERRORS_JOB_ID_COLUMN=
SMITH_ERRORS_TOOL_ID_COLUMN=
SMITH_ERRORS_CREATED_AT_COLUMN=created_at
SMITH_ERRORS_MESSAGE_COLUMN=message
SMITH_ERRORS_SEVERITY_COLUMN=
SMITH_ERRORS_RAW_PAYLOAD_COLUMN=
SMITH_APPROVALS_ID_COLUMN=id
SMITH_APPROVALS_JOB_ID_COLUMN=
SMITH_APPROVALS_STATUS_COLUMN=status
SMITH_APPROVALS_APPROVAL_TYPE_COLUMN=
SMITH_APPROVALS_CREATED_AT_COLUMN=created_at
SMITH_APPROVALS_REQUESTED_BY_COLUMN=

# n8n integration
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=

# Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# LLM integration
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=

# Logging
LOG_LEVEL=INFO
