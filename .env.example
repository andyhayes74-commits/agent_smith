# Agent Smith runtime
SMITH_ENV=development
SMITH_PERMISSION_LEVEL=0
SMITH_SERVICE_NAME=agent-smith

# Database
DATABASE_URL=postgres://smith:smith_password@postgres:5432/smith

# n8n integration
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=

# Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# LLM integration
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=

# Logging
LOG_LEVEL=INFO
